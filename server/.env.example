# ─── Server Configuration ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB Connection ────────────────────────────────────────────────────────
# Replace with your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/savory-skies?retryWrites=true&w=majority
DB_NAME=savory-skies

# ─── JWT Configuration ────────────────────────────────────────────────────────
JWT_SECRET=savory_skies_super_secret_jwt_key_change_me_in_production
JWT_EXPIRES_IN=7d

# ─── Client URL (for CORS) ────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
